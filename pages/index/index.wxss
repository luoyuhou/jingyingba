page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #f4f4f4;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 !important;
  align-items: stretch !important;
  justify-content: flex-start !important;
  overflow: hidden;
  height: 0; /* 关键：强制 flex 子元素在 overflow 时正确计算高度 */
}

.header {
  padding: 60rpx 40rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-area {
  flex: 1;
}

.scan-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-left: 20rpx;
}

.scan-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.scan-text {
  font-size: 20rpx;
  color: #666;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.list-wrapper {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.store-list {
  flex: 1;
  height: 0;
}

.store-item {
  background-color: #fff;
  padding: 30rpx 40rpx;
  margin-bottom: 2rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.store-item:active {
  background-color: #fafafa;
}

.store-info {
  flex: 1;
}

.store-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.store-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #ccc;
  border-right: 4rpx solid #ccc;
  transform: rotate(45deg);
  margin-left: 20rpx;
}

.empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.footer {
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  flex-shrink: 0;
  border-top: 1rpx solid #eee;
}

.apply-store-btn {
  width: 100% !important;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: normal;
}

.logout-btn {
  width: 100% !important;
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f !important;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: normal;
}

