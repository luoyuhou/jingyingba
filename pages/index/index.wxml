<view class="container">
  <view class="header">
    <view class="header-content">
      <view class="title-area">
        <text class="title">请选择要进入的门店</text>
        <text class="subtitle">当前账号关联的所有门店</text>
      </view>
      <view class="scan-btn" bindtap="onScanLogin">
        <image class="scan-icon" src="/static/img/scan-code.png" mode="aspectFit"></image>
        <text class="scan-text">登录PC端</text>
      </view>
    </view>
  </view>

  <view class="list-wrapper">
    <scroll-view scroll-y class="store-list">
      <view 
        class="store-item" 
        wx:for="{{stores}}" 
        wx:key="store_id" 
        bindtap="selectStore" 
        data-id="{{item.store_id}}"
        data-name="{{item.store_name}}"
      >
        <view class="store-info">
          <text class="store-name">{{item.store_name}}</text>
          <text class="store-address">{{item.province_name}}{{item.city_name}}{{item.area_name}}{{item.address}}</text>
        </view>
        <view class="arrow"></view>
      </view>
      
      <view class="empty" wx:if="{{stores.length === 0 && !loading}}">
        <text>未发现关联门店，请先提交门店申请</text>
      </view>

      <view style="margin-top: 40rpx; padding: 0 40rpx;">
        <button class="apply-store-btn" bindtap="navToApply" type="primary" plain="true">申请新门店</button>
      </view>
    </scroll-view>
  </view>
  
  <view class="footer">
    <button class="logout-btn" bindtap="onLogout">切换账户</button>
  </view>
</view>