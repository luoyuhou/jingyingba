<navigation-bar title="结算确认" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<wxs module="priceUtils">
  module.exports.toFixed = function(val) {
    if (!val) return '0.00';
    return parseFloat(val).toFixed(2);
  }
  module.exports.formatQty = function(item) {
    if (!item) return '';
    if (item.billingMode === 'weight') {
      return item.quantity + 'g';
    }
    return 'x' + item.quantity + '个';
  }

  module.exports.getSubtotal = function(item) {
    if (!item) return '0.00';
    var price = parseFloat(item.price) || 0;
    var qty = parseFloat(item.quantity) || 0;
    if (item.billingMode === 'weight') {
      return (price * qty / 500).toFixed(2);
    }
    return (price * qty).toFixed(2);
  }
</wxs>
<scroll-view class="scrollarea" scroll-y>
  <view class="container">
    <!-- 会员搜索/信息 -->
    <view class="section">
      <view class="section-title">会员信息</view>
      <view class="member-search" wx:if="{{!member}}">
        <input class="search-input" placeholder="输入手机号查找会员" bindinput="onPhoneInput" type="number" value="{{searchPhone}}" />
        <button class="search-btn" bindtap="searchMember" size="mini">查找</button>
      </view>
      <view class="member-info-box" wx:else>
        <view class="m-user">
          <text class="m-name">{{member.name}}</text>
          <text class="m-phone">{{member.phone}}</text>
          <text class="change-member" bindtap="setData" data-member="{{null}}">更换</text>
        </view>
        <view class="m-stats">
          <view class="stat-item">
            <text class="label">积分</text>
            <text class="value">{{member.points}}</text>
          </view>
          <view class="stat-item">
            <text class="label">余额</text>
            <text class="value">￥{{priceUtils.toFixed(member.balance)}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单明细 -->
    <view class="section">
      <view class="section-title">订单明细</view>
      <view class="item-list">
        <view class="order-item" wx:for="{{order.items}}" wx:key="id">
          <view class="item-main">
            <view class="name">{{item.name}}</view>
            <view class="detail">
              <text class="unit-price">￥{{item.price}}/{{item.billingMode === 'weight' ? '500g' : '件'}}</text>
              <text class="qty">{{priceUtils.formatQty(item)}}</text>
            </view>
          </view>
          <text class="price">￥{{priceUtils.getSubtotal(item)}}</text>
        </view>
      </view>
      <view class="total-row">
        <view class="points-gain">预计可得积分: +{{expectedPoints}}</view>
        <view class="total-amount">合计: <text class="p">￥{{priceUtils.toFixed(order.totalAmount)}}</text></view>
      </view>
      <view class="total-row discount-row" wx:if="{{usePoints}}">
        <view class="points-gain">积分抵扣 ({{pointsToUse}} 积分)</view>
        <view class="total-amount">-￥{{priceUtils.toFixed(discountAmount)}}</view>
      </view>
    </view>

    <!-- 优惠抵扣 -->
    <view class="section" wx:if="{{member}}">
      <view class="points-deduction">
        <view class="pd-header">
          <view class="pd-title">积分抵扣</view>
          <view class="pd-tip {{isRedemptionDay ? 'active' : ''}}">
            {{isRedemptionDay ? '今日可抵扣' : '今日不可用'}}
          </view>
          <switch bindchange="togglePoints" checked="{{usePoints}}" disabled="{{!isRedemptionDay}}" />
        </view>
        <view class="pd-detail" wx:if="{{usePoints}}">
          <text>消耗积分: {{pointsToUse}}</text>
          <text class="minus">-￥{{priceUtils.toFixed(discountAmount)}}</text>
        </view>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="section">
      <view class="section-title">支付方式</view>
      <view class="payment-methods">
        <view class="method-item {{paymentMethod === 'cash' ? 'active' : ''}}" bindtap="selectPaymentMethod" data-method="cash">
          <icon type="success" size="20" color="{{paymentMethod === 'cash' ? '#07c160' : '#ddd'}}"></icon>
          <text>现金支付</text>
        </view>
        <view class="method-item {{paymentMethod === 'balance' ? 'active' : ''}} {{(!member || member.balance < payableAmount) ? 'disabled' : ''}}" bindtap="selectPaymentMethod" data-method="balance">
          <icon type="success" size="20" color="{{paymentMethod === 'balance' ? '#07c160' : '#ddd'}}"></icon>
          <text>会员余额 (￥{{priceUtils.toFixed(member.balance)}})</text>
        </view>
      </view>
    </view>

    <!-- 底部占位，防止最后一个 section 被 footer-bar 遮挡 -->
    <view style="height: 30rpx;"></view>
  </view>
</scroll-view>

<!-- 底部结算栏，位于 scroll-view 之外 -->
<view class="footer-bar">
  <view class="final-info">
    <text class="label">实付金额</text>
    <text class="amount">￥{{priceUtils.toFixed(payableAmount)}}</text>
  </view>
  <button class="confirm-btn" type="primary" bindtap="confirmPayment">确认支付</button>
</view>