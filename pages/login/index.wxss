.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  padding: 0 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.nickname {
  font-size: 28rpx;
  color: #666;
}

.login-btn {
  width: 80%;
  background-color: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  border: none;
}

.tips {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
}

/* 绑定手机号样式 */
.bind-section {
  width: 100%;
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  text-align: center;
}

.input-group {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
}

.input {
  width: 100%;
  height: 60rpx;
  font-size: 30rpx;
}

.sms-group {
  display: flex;
  align-items: center;
}

.sms-btn {
  font-size: 24rpx;
  color: #07c160;
  background: none;
  padding: 0 20rpx;
  border-left: 1rpx solid #eee;
  white-space: nowrap;
  line-height: 1.5;
}

.sms-btn.disabled {
  color: #999;
}

.submit-btn {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  margin-top: 50rpx;
}

.back-btn {
  text-align: center;
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #666;
}