.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f8f8;
}

.header-actions {
  display: flex;
  align-items: center;
  padding: 10rpx 15rpx;
  background: #fff;
  gap: 15rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
  font-size: 24rpx;
}

.btn-add-top {
  margin: 0 !important;
  border-radius: 30rpx;
  background: #07c160 !important;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.container {
  padding: 0 1rpx 40rpx;
}

/* 表格样式 */
.table-header {
  display: flex;
  background: #f0f0f0;
  padding: 15rpx 0;
  border-bottom: 2rpx solid #ddd;
  width: 100%;
}

.table-body {
  background: #fff;
  width: 100%;
}

.tr {
  display: flex;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
  align-items: center;
  width: 100%;
}

.tr:last-child {
  border-bottom: none;
}

.th, .td {
  font-size: 24rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 0;
}

/* 列宽分配 - 重新微调占比 */
.name { width: 22%; }
.count { width: 10%; }
.amount { width: 20%; }
.balance { width: 20%; }
.points { width: 13%; }
.action { 
  width: 15%; 
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.th {
  font-weight: bold;
  color: #333;
}

.td {
  color: #666;
}

.name.td {
  color: #333;
  font-weight: 500;
}

.amount.td, .balance.td {
  color: #e64340;
}

.btn-op {
  font-size: 24rpx;
  margin: 4rpx 0;
  padding: 4rpx 4rpx;
  border-radius: 4rpx;
  width: 60%;
  text-align: center;
}

.recharge { color: #07c160; border: 1rpx solid #07c160; }
.record { color: #10aeff; border: 1rpx solid #10aeff; }
.delete { color: #e64340; border: 1rpx solid #e64340; }

.empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
}

.modal-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 充值弹窗特有样式 */
.recharge-modal {
  width: 95%;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.recharge-section {
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed #eee;
}

.highlight {
  color: #e64340;
  font-weight: bold;
}

.recharge-form {
  margin-top: 20rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.form-row .label {
  width: 140rpx;
  font-size: 26rpx;
  color: #666;
}

.form-row .input {
  flex: 1;
  margin-bottom: 0 !important;
  height: 70rpx;
  padding: 0 20rpx;
}

.btn-confirm-recharge {
  width: 100% !important;
  height: 80rpx;
  line-height: 50rpx;
  background: #07c160 !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-top: 10rpx;
}

.logs-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin-top: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

/* 记录小表格 */
.mini-table {
  flex: 1;
  display: flex;
  flex-direction: column;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
}

.mini-th-group {
  display: flex;
  background: #f9f9f9;
  border-bottom: 1rpx solid #eee;
}

.mini-th {
  flex: 1;
  font-size: 24rpx;
  font-weight: bold;
  padding: 15rpx 5rpx;
  text-align: center;
}

.mini-table-body {
  height: 400rpx;
}

.mini-tr {
  display: flex;
  border-bottom: 1rpx solid #f5f5f5;
}

.mini-td {
  flex: 1;
  font-size: 24rpx;
  padding: 20rpx 5rpx;
  text-align: center;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-td.date {
  font-size: 24rpx;
  line-height: 1.2;
}

.empty-mini {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.modal-footer {
  margin-top: 30rpx;
}

.btn-close-full {
  width: 100%;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 通用输入框和按钮 */
.input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btns button {
  flex: 1;
  border-radius: 40rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

/* 标签样式 */
.tag {
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.recharge-tag {
  background: #e8f7ed;
  color: #07c160;
}

.consume-tag {
  background: #fff0ed;
  color: #ff4400;
}
