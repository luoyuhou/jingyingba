.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f7f7;
}

.order-list {
  flex: 1;
  height: 0; /* 必须设置，配合 flex: 1 触发滚动 */
}

.order-item {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.header .left {
  display: flex;
  flex-direction: column;
}

.customer {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-top: 4rpx;
}

.status.completed {
  color: #07c160;
}

.status.pending {
  color: #ff9900;
}

.content {
  margin-bottom: 20rpx;
}

.items {
  font-size: 28rpx;
  color: #333;
}

.p-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #555;
  border-bottom: 1rpx dotted #f5f5f5;
}

.p-name {
  flex: 2;
}

.p-qty {
  flex: 1;
  text-align: center;
  color: #999;
}

.p-subtotal {
  flex: 1;
  text-align: right;
  font-weight: 500;
  color: #333;
}

.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15rpx;
}

.payment-method {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f7ed;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  height: 40rpx;
  line-height: 15rpx;
}

.total {
  text-align: right;
  font-size: 32rpx;
}

.price {
  color: #ff4400;
  font-weight: bold;
}

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #999;
}
