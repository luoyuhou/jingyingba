.header-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.btn-add-top {
  margin: 0 !important;
  border-radius: 30rpx;
  background: #07c160 !important;
  font-size: 24rpx;
  padding: 0 30rpx;
}

.container {
  padding: 0 1rpx 40rpx;
}

/* 表格样式 */
.table-header {
  display: flex;
  background: #f0f0f0;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #ddd;
  width: 100%;
}

.table-body {
  background: #fff;
  width: 100%;
}

.tr {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  align-items: center;
  width: 100%;
}

.tr:last-child {
  border-bottom: none;
}

.th, .td {
  font-size: 24rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 列宽分配 */
.name { width: 20%; text-align: left; padding-left: 20rpx; }
.username { width: 30%; }
.status { width: 20%; }
.action { 
  width: 30%; 
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.th {
  font-weight: bold;
  color: #333;
}

.td {
  color: #666;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.status-tag.active {
  background: #e6f7ed;
  color: #07c160;
}

.status-tag.disabled {
  background: #fff1f0;
  color: #f5222d;
}

.btn-op {
  font-size: 24rpx;
  margin: 4rpx 0;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  width: 70%;
  text-align: center;
  border: 1rpx solid transparent;
}

.edit { color: #2f80ed; border-color: #2f80ed; }
.toggle.disable { color: #faad14; border-color: #faad14; }
.toggle.enable { color: #07c160; border-color: #07c160; }
.delete { color: #e64340; border-color: #e64340; }

.empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
}

.modal-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.input {
  background: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btns button {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}
