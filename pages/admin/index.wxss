.container {
  padding: 20rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-item {
  width: 45%;
  background: #fff;
  margin-bottom: 30rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.grid-item .icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.grid-item text:last-child {
  font-size: 28rpx;
  color: #333;
}
