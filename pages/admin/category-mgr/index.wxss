.mgr-container {
  display: flex;
  height: calc(100vh - 180rpx);
  background: #f8f8f8;
}

.sidebar {
  width: 200rpx;
  background: #fff;
  border-right: 1rpx solid #eee;
}

.cat-item {
  padding: 30rpx 20rpx;
  font-size: 26rpx;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
  color: #666;
}

.cat-item.active {
  background: #f8f8f8;
  color: #07c160;
  font-weight: bold;
  border-left: 8rpx solid #07c160;
}

.add-btn-item {
  padding: 30rpx 20rpx;
  text-align: center;
  color: #07c160;
  font-size: 40rpx;
}

.main-content {
  flex: 1;
  padding: 30rpx;
}

.detail-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.detail-card .title {
  display: block;
  font-weight: bold;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}

.action-item {
  margin-bottom: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.btns {
  display: flex;
  justify-content: flex-end;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}

.modal-title {
  display: block;
  text-align: center;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.input {
  border: 1rpx solid #ddd;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  justify-content: space-around;
}
