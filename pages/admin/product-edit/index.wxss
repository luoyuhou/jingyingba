.edit-container {
  display: flex;
  height: calc(100vh - 180rpx);
  background: #f8f8f8;
}

.sidebar {
  width: 220rpx;
  background: #fff;
  border-right: 1rpx solid #eee;
}

.sidebar-title {
  padding: 30rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
  background: #fafafa;
}

.cat-item {
  padding: 30rpx 20rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  margin-right: 15rpx;
  position: relative;
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 8rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  top: 6rpx;
  left: 6rpx;
}

.cat-item.active {
  color: #07c160;
  background: #f0fdf4;
}

.main-form {
  flex: 1;
  padding: 30rpx;
}

.form-card {
  background: #fff;
  padding: 0 30rpx;
  border-radius: 16rpx;
}

.form-item {
  padding: 40rpx 0;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.input {
  font-size: 36rpx;
  font-weight: 500;
}

.tip-box {
  margin-top: 30rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.footer {
  margin-top: 60rpx;
  padding-bottom: 100rpx;
}
