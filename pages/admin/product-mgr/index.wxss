.mgr-container {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 180rpx);
  background: #f8f8f8;
}

.header-tools {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.search-bar {
  background: #f5f5f5;
  padding: 15rpx 25rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  flex: 1;
}

.add-p-btn {
  margin: 0 !important;
  white-space: nowrap;
}

.search-input {
  flex: 1;
  margin-left: 15rpx;
  font-size: 26rpx;
}

.stats-panel {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item .num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-item .label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.color-green { color: #07c160 !important; }
.color-red { color: #fa5151 !important; }
.color-orange { color: #ff9900 !important; }

.content-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.sidebar {
  width: 180rpx;
  background: #fff;
  border-right: 1rpx solid #eee;
}

.cat-item {
  padding: 30rpx 15rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
  color: #666;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.cat-item.active {
  background: #f8f8f8;
  color: #07c160;
  font-weight: bold;
  border-left: 6rpx solid #07c160;
}

.main-list {
  flex: 1;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
}

.status-tag {
  font-size: 18rpx;
  background: #999;
  color: #fff;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
}

.status-off {
  background: #fafafa !important;
}

.status-off .name, .status-off .price {
  color: #bbb;
}

.data-row {
  display: flex;
  align-items: center;
  margin: 8rpx 0;
}

.price {
  color: #ff4400;
  font-size: 26rpx;
  margin-right: 20rpx;
}

.sold-count {
  font-size: 22rpx;
  color: #999;
}

.categories {
  font-size: 22rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 10rpx;
}

.empty-tip {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}

.modal-title {
  display: block;
  text-align: center;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.input {
  border: 1rpx solid #ddd;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  justify-content: space-around;
}

/* 商品表单弹窗特有样式 */
.product-modal {
  width: 85% !important;
}

.p-form {
  padding: 20rpx 0;
}

.p-form-item {
  margin-bottom: 30rpx;
}

.p-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.p-input {
  border: 1rpx solid #ddd;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.p-radio-group {
  display: flex;
  gap: 30rpx;
  margin-top: 10rpx;
}

.p-radio-label {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.p-cat-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.p-cat-tag {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #333;
}

.p-cat-tag.active {
  background: #07c160;
  color: #fff;
}
